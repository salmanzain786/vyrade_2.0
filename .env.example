# --- MySQL ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=vyrade
DB_PASSWORD=changeme
DB_NAME=vyrade_blueprint

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- Token pricing (for per-conversation cost accounting) ---
# Cost is computed from a per-model rate table in lib/config/pricing.js (USD per
# 1M tokens). Those defaults are APPROXIMATE — update them to your real rates.
# Optionally override the active model's rate here without editing code:
# OPENAI_PRICE_INPUT=0.25    # USD per 1M input (prompt) tokens
# OPENAI_PRICE_OUTPUT=2.00   # USD per 1M output (completion) tokens

# --- Pinecone: n8n node knowledge (primary account) ---
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX=n8n-nodes
PINECONE_NAMESPACE=n8n-nodes
# Embedding model used to BUILD the indexes (query vectors must match dimension)
EMBEDDING_MODEL=text-embedding-3-large

# --- Pinecone: n8n workflow examples (separate account) ---
# Real workflows used as structural templates. Pinecone returns metadata.mysql_id;
# the full WORKFLOW_JSON is hydrated from MySQL (n8n_node_workflows) and compacted
# to a skeleton. Optional — unset means generation uses node + tool knowledge only.
PINECONE_WORKFLOW_EXAMPLE_API_KEY=pcsk_...
PINECONE_WORKFLOW_EXAMPLE_INDEX=n8nworkflows
PINECONE_WORKFLOW_EXAMPLE_NAMESPACE=
# The misspelled PINECONE_WORKFLOW_EXMAPLE_* variants are also accepted.
# Where the example rows live (defaults to this app's DB / n8n_node_workflows):
# WORKFLOW_EXAMPLE_DB=
# WORKFLOW_EXAMPLE_TABLE=n8n_node_workflows

# --- Pinecone: Vyrade tools (separate account) — tools + API docs ---
# When set, workflow generation ALSO retrieves relevant tools and wires them as
# n8n HTTP Request nodes. Leave unset to generate from n8n nodes alone.
PINECONE_TOOL_API_KEY=pcsk_...
PINECONE_TOOL_INDEX=vyradetools
PINECONE_TOOL_NAMESPACE=n8n-nodes
# Optional: only if the tools index was built with a different embedding model
# PINECONE_TOOL_EMBEDDING_MODEL=text-embedding-3-large

# --- Pinecone: Vyrade MCP (separate account) — MCP connectors + docs ---
# Powers the Claude Code export package's recommended-mcps.md. Leave unset to
# still produce the package (recommending API/custom integration instead).
PINECONE_MCP_API_KEY=pcsk_...
PINECONE_MCP_INDEX=vyrade-mcp
PINECONE_MCP_NAMESPACE=
# PINECONE_MCP_EMBEDDING_MODEL=text-embedding-3-large

# --- Pinecone: Make.com modules (separate account) — Task 11 ---
# Powers the Make.com implementation-guide export. Isolated from n8n/Claude.
PINECONE_MAKE_API_KEY=pcsk_...
PINECONE_MAKE_INDEX=makenodes
PINECONE_MAKE_NAMESPACE=
# PINECONE_MAKE_EMBEDDING_MODEL=text-embedding-3-large

# --- Pinecone: Zapier actions (separate account) — placeholder, Task 11 ---
# Unset → Zapier shows "Coming soon". Add these to enable the Zapier guide.
# PINECONE_ZAPIER_API_KEY=pcsk_...
# PINECONE_ZAPIER_INDEX=zapiernodes
# PINECONE_ZAPIER_NAMESPACE=

# --- n8n import smoke test (optional but recommended before production) ---
# When set, every generated workflow is POSTed to a THROWAWAY n8n instance to
# prove it actually imports. If n8n rejects it, its error is fed back to the
# model for repair; the smoke-test workflow is deleted afterwards. Unset → the
# check is skipped and generation behaves exactly as before.
# Use a disposable instance — never production n8n.
# N8N_TEST_URL=https://n8n-test.internal
# N8N_TEST_API_KEY=n8n_api_...
# N8N_TEST_TIMEOUT_MS=15000

# --- Auth audit retention (auth_attempts) ---
# The audit/rate-limit table holds email + IP, so it is pruned in two tiers.
# Rate limiting only needs the last ~60 minutes; the rest is for investigation.
#   <= ANONYMIZE_AFTER_DAYS : full detail
#   .. RETAIN_DAYS          : email/ip stripped, event/outcome/time kept
#   >  RETAIN_DAYS          : deleted
# The app prunes opportunistically (max once/hour); run `npm run cleanup:auth-audit`
# from cron for a deterministic schedule.
# AUTH_AUDIT_ANONYMIZE_AFTER_DAYS=30
# AUTH_AUDIT_RETAIN_DAYS=90

# --- Deployment: trusted proxy (affects per-IP rate limiting) ---
# X-Forwarded-For is client-supplied unless a proxy YOU control appends to it,
# so it is IGNORED by default. Set this to the number of trusted proxies in
# front of the app; the client IP is then read as that many entries from the
# RIGHT of the header (a spoofed value on the left is discarded).
#   unset / 0 / false → don't trust XFF (correct when directly exposed)
#   1                 → one proxy (Nginx, ALB, Cloudflare, Vercel…)
#   2                 → two hops (e.g. Cloudflare → Nginx → app)
# Platform headers (CF-Connecting-IP, Vercel, True-Client-IP) are always used
# when present, because the edge overwrites whatever the client sent.
# Leaving this unset behind a proxy makes per-IP limits inactive (per-email
# limits still apply) and logs a warning.
# TRUST_PROXY=1

# --- Auth ---
# Secret used to sign session + password-reset tokens (HMAC). Use a long random
# string (min 16 chars). Generate one, e.g.:  openssl rand -base64 48
AUTH_SECRET=change-me-to-a-long-random-string

# --- Email (OTP delivery) ---
# Optional. If unset (or `nodemailer` isn't installed), OTP codes are printed to
# the server console so the flows work in local dev with zero setup.
# To send real email:  npm install nodemailer  and fill these in.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-smtp-password
# SMTP_FROM=Vyrade <no-reply@vyrade.com>
