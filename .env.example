# --- MySQL ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=vyrade
DB_PASSWORD=changeme
DB_NAME=vyrade_blueprint

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- Auth ---
# Secret used to sign session + password-reset tokens (HMAC). Use a long random
# string (min 16 chars). Generate one, e.g.:  openssl rand -base64 48
AUTH_SECRET=change-me-to-a-long-random-string

# --- Email (OTP delivery) ---
# Optional. If unset (or `nodemailer` isn't installed), OTP codes are printed to
# the server console so the flows work in local dev with zero setup.
# To send real email:  npm install nodemailer  and fill these in.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-smtp-password
# SMTP_FROM=Vyrade <no-reply@vyrade.com>
